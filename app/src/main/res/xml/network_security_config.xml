<?xml version="1.0" encoding="utf-8"?>
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <!-- Need to allow cleartext traffic for some sources -->
    <base-config
        cleartextTrafficPermitted="true"
        tools:ignore="InsecureBaseConfiguration">
        <trust-anchors>
            <!-- Trust preinstalled CAs. User-added CAs are trusted in debug builds only
                 (see src/debug/res/xml/network_security_config.xml) so release builds are not
                 exposed to user-installed interception certificates. -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
